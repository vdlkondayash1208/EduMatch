# =============================================
# EduMatch Backend - Environment Variables
# =============================================
# Copy this file to .env for local development.
# On Render, set these in Dashboard > Environment.

# Application environment
APP_ENV=production

# Frontend origin(s) for CORS (comma-separated if multiple)
FRONTEND_ORIGIN=https://vdlkondayash1208.github.io

# OpenRouter API key (required for AI features)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://vdlkondayash1208.github.io
OPENROUTER_APP_NAME=EduMatch

# Supabase (optional - for persistent cloud storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MySQL (optional - for request audit logging)
MYSQL_DSN=
